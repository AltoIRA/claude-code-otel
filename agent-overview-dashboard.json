          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 6
      },
      "id": 14,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service_name=\"claude-code\"} |= \"claude_code.api_request\" [$__interval]))",
          "legendFormat": "Claude",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service_name=~\"codex_cli_rs|codex-app-server\"} | event_name = \"codex.sse_event\" | event_kind = \"response.completed\" [$__interval])) + sum(count_over_time({service_name=~\"codex_cli_rs|codex-app-server\"} | event_name = \"codex.websocket_event\" | event_kind = \"response.completed\" [$__interval]))",
          "legendFormat": "Codex",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service_name=\"warp\"} | json | event != \"\" [$__interval])) or vector(0)",
          "legendFormat": "Warp",
          "refId": "C"
        }
      ],
      "title": "Activity Over Time",
      "type": "timeseries",
      "description": "Request/response/interaction volume by agent over time."
    },
    {
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "Error rate",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "vis": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 6
      },
      "id": 15,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "(sum(count_over_time({service_name=\"claude-code\"} |= \"claude_code.api_error\" [$__interval])) or vector(0)) / clamp_min(sum(count_over_time({service_name=\"claude-code\"} |= \"claude_code.api_request\" [$__interval])), 1)",
          "legendFormat": "Claude",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "(sum(count_over_time({service_name=~\"codex_cli_rs|codex-app-server\"} | http_response_status_code != \"\" | http_response_status_code != \"200\" [$__interval])) or vector(0)) / clamp_min(sum(count_over_time({service_name=~\"codex_cli_rs|codex-app-server\"} | event_name = \"codex.sse_event\" | event_kind = \"response.completed\" [$__interval])) + sum(count_over_time({service_name=~\"codex_cli_rs|codex-app-server\"} | event_name = \"codex.websocket_event\" | event_kind = \"response.completed\" [$__interval])), 1)",
          "legendFormat": "Codex",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "(sum(count_over_time({service_name=\"warp\"} |= \"\\\"was_user_facing_error\\\":true\" | json [$__interval])) or vector(0)) / clamp_min(sum(count_over_time({service_name=\"warp\"} | json | event != \"\" [$__interval])), 1)",
          "legendFormat": "Warp",
          "refId": "C"
        }
      ],
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "description": "Errors divided by activity for each agent, so busy agents are not penalized just for higher volume."
