  "description": "Unified high-level overview across Claude Code, Codex CLI, and Warp.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "title": "Estimated Cost",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Claude Code reports native USD cost on API request logs.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} |= \"claude_code.api_request\" | unwrap cost_usd [$__range]))",
          "legendFormat": "Claude",
          "refId": "A"
        }
      ],
      "title": "Claude",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Codex cost is estimated from response token counts using the same pricing assumptions as the Codex dashboard.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(sum_over_time({service_name=~\"codex_cli_rs|codex-app-server\"} | input_token_count != \"\" | unwrap input_token_count [$__range])) * 2.50 / 1000000 + sum(sum_over_time({service_name=~\"codex_cli_rs|codex-app-server\"} | cached_token_count != \"\" | unwrap cached_token_count [$__range])) * 0.25 / 1000000 + sum(sum_over_time({service_name=~\"codex_cli_rs|codex-app-server\"} | output_token_count != \"\" | unwrap output_token_count [$__range])) * 15.00 / 1000000",
          "legendFormat": "Codex",
          "refId": "A"
        }
      ],
      "title": "Codex",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Warp cost is estimated from local conversation credits using WARP_ESTIMATED_CENTS_PER_CREDIT. The current default is 1.5 cents per credit until the actual Enterprise rate is known.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(warp_conversation_model_estimated_spend_cents_total and on(conversation_id, workspace_uid) ((time() - warp_conversation_last_updated_timestamp_seconds) <= $__range_s)) / 100",
          "legendFormat": "Warp",
          "refId": "A"
        }
      ],
      "title": "Warp",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "title": "Comparison Trends",
      "type": "row"
    },
    {
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "description": "Selected-range token share by agent. Claude and Codex come from logs; Warp uses conversations updated in the selected range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 6
      },
      "id": 13,
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "percent"
          ]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} |= \"claude_code.api_request\" | unwrap input_tokens [$__range])) + sum(sum_over_time({service_name=\"claude-code\"} |= \"claude_code.api_request\" | unwrap output_tokens [$__range])) + sum(sum_over_time({service_name=\"claude-code\"} |= \"claude_code.api_request\" | unwrap cache_read_tokens [$__range])) + sum(sum_over_time({service_name=\"claude-code\"} |= \"claude_code.api_request\" | unwrap cache_creation_tokens [$__range]))",
          "legendFormat": "Claude",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(sum_over_time({service_name=~\"codex_cli_rs|codex-app-server\"} | input_token_count != \"\" | unwrap input_token_count [$__range])) + sum(sum_over_time({service_name=~\"codex_cli_rs|codex-app-server\"} | output_token_count != \"\" | unwrap output_token_count [$__range]))",
          "legendFormat": "Codex",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(warp_conversation_tokens_total and on(conversation_id, workspace_uid) ((time() - warp_conversation_last_updated_timestamp_seconds) <= $__range_s)) or vector(0)",
          "legendFormat": "Warp",
          "refId": "C"
        }
      ],
      "title": "Token Share",
      "type": "piechart"
    },
